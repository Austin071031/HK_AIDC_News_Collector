# ==========================================
# Environment Variables Configuration
# ==========================================

# Application Environment (development, test, production)
# Default: development
APP_ENV=development

# Database Connection String
# Default: sqlite+pysqlite:///./app.db
DATABASE_URL=sqlite+pysqlite:///./app.db

# ------------------------------------------
# LLM (Language Model) Configuration
# ------------------------------------------

# OpenAI API Key (Required if using OpenAI models like gpt-4o-mini)
OPENAI_API_KEY=

# Custom LLM API Key (Required if using an OpenAI-compatible endpoint like DeepSeek, OpenRouter, etc.)
# If you are using DeepSeek, enter your sk-xxxxxxxxxx here
LLM_API_KEY=

# Custom LLM Base URL (Optional)
# If using deepseek, the code will automatically set this to https://api.deepseek.com/v1 if left empty.
LLM_BASE_URL=

# The LLM model to use for article filtering and enrichment
# Examples: gpt-4o-mini, deepseek-chat, deepseek-reasoner
# Default: gpt-4o-mini
LLM_MODEL=deepseek-chat

# ------------------------------------------
# Scraping / Crawling Configuration
# ------------------------------------------

# Firecrawl API Key (Used as a fallback to scrape sites protected by Cloudflare)
# Get it from: https://firecrawl.dev/
FIRECRAWL_API_KEY=your_firecrawl_api_key_here

# Firecrawl Base URL
# Default: https://api.firecrawl.dev
FIRECRAWL_BASE_URL=https://api.firecrawl.dev

# ------------------------------------------
# App Preferences
# ------------------------------------------

# Default limit for API list queries (min: 1, max: 100)
# Default: 25
DEFAULT_QUERY_LIMIT=25
